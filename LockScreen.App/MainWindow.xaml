<Window x:Class="LockScreen.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LockScreen.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Lock Screen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        KeyDown="Window_OnKeyDown">

    <Window.Resources>
        <DrawingBrush x:Key="DotGridBrush"
                      TileMode="Tile"
                      Viewport="0,0,14,14"
                      ViewportUnits="Absolute"
                      Viewbox="0,0,14,14"
                      ViewboxUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#00000000" Geometry="M0,0 H14 V14 H0 Z" />
                    <GeometryDrawing Brush="#18FFFFFF" Geometry="M5,5 A2,2 0 1 1 9,5 A2,2 0 1 1 5,5 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="SettingsInput" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E8FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#5000AAFF" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CharacterCasing" Value="Upper" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ThemeBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#99FFFFFF" />
            <Setter Property="Background" Value="#12FFFFFF" />
            <Setter Property="BorderBrush" Value="#20FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF" />
                    <Setter Property="BorderBrush" Value="#40FFFFFF" />
                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="Foreground" Value="#99FFFFFF" />
            <Setter Property="BorderBrush" Value="#25FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="50"
                                Width="36"
                                Height="36">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30FFFFFF" />
                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallIconBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="50"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{Binding BackgroundBaseBrush}">
        <Rectangle Fill="{Binding GlowTopLeftBrush}" />
        <Rectangle Fill="{Binding GlowTopRightBrush}" />
        <Rectangle Fill="{Binding GlowBottomBrush}" />
        <Rectangle Fill="{StaticResource DotGridBrush}" Opacity="0.8" />

        <Grid Margin="64">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Border HorizontalAlignment="Left"
                        Padding="26"
                        CornerRadius="20"
                        Background="#14000000"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1">
                    <StackPanel>
                        <controls:DotMatrixTextBlock Text="{Binding TitleText}"
                                                     DotSize="6"
                                                     DotGap="4"
                                                     CharacterSpacing="2"
                                                     OnBrush="#CCFFFFFF"
                                                     OffBrush="#18FFFFFF"
                                                     GlowBrush="#60FFFFFF" />

                        <controls:DotMatrixTextBlock Margin="0,18,0,0"
                                                     Text="{Binding CurrentTime}"
                                                     DotSize="12"
                                                     DotGap="6"
                                                     CharacterSpacing="2"
                                                     OnBrush="#FFFFFFFF"
                                                     OffBrush="#14FFFFFF"
                                                     GlowBrush="#90FFFFFF" />

                        <controls:DotMatrixTextBlock Margin="0,12,0,0"
                                                     Text="{Binding CurrentDate}"
                                                     DotSize="5"
                                                     DotGap="4"
                                                     CharacterSpacing="1"
                                                     OnBrush="#D9F7FFFF"
                                                     OffBrush="#142CCEFF"
                                                     GlowBrush="#7025E9FF" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    Padding="20,14"
                    Background="#12000000"
                    BorderBrush="#1FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="16">
                <DockPanel>
                    <controls:DotMatrixTextBlock DockPanel.Dock="Left"
                                                 Text="{Binding StatusMessage}"
                                                 DotSize="3"
                                                 DotGap="3"
                                                 CharacterSpacing="1"
                                                 OnBrush="#9BE8FFFF"
                                                 OffBrush="#102CCEFF"
                                                 GlowBrush="#5025E9FF" />
                    <controls:DotMatrixTextBlock HorizontalAlignment="Right"
                                                 Text="{Binding DismissText}"
                                                 DotSize="3"
                                                 DotGap="3"
                                                 CharacterSpacing="1"
                                                 OnBrush="#CCFFFFFF"
                                                 OffBrush="#14FFFFFF"
                                                 GlowBrush="#70FFFFFF" />
                </DockPanel>
            </Border>
        </Grid>

        <Grid VerticalAlignment="Bottom"
              HorizontalAlignment="Right"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="SettingsHintBubble"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,10"
                    Padding="10,6"
                    Background="#A6101420"
                    BorderBrush="#35FFFFFF"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                <TextBlock Text="setting me"
                           Foreground="#E8FFFFFF"
                           FontFamily="Consolas"
                           FontSize="11" />
            </Border>

            <Button Grid.Row="1"
                    Style="{StaticResource IconBtn}"
                    HorizontalAlignment="Right"
                    Command="{Binding ToggleSettingsPanelCommand}"
                    ToolTip="Settings"
                    Content="⚙" />
        </Grid>

        <Rectangle Fill="#01000000"
                   MouseLeftButtonDown="SettingsOverlay_OnMouseLeftButtonDown">
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="360"
                Background="#EE060912"
                BorderBrush="#28FFFFFF"
                BorderThickness="1,0,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsPanelOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="28,36,28,28">
                    <DockPanel Margin="0,0,0,28">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource SmallIconBtn}"
                                Command="{Binding ToggleSettingsPanelCommand}"
                                Content="×" />
                        <controls:DotMatrixTextBlock Text="SETTINGS"
                                                     DotSize="4"
                                                     DotGap="2"
                                                     CharacterSpacing="1"
                                                     OnBrush="#FFFFFFFF"
                                                     OffBrush="#18FFFFFF"
                                                     GlowBrush="#60FFFFFF"
                                                     VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBlock Text="TEXTS"
                               Foreground="#60FFFFFF"
                               FontFamily="Consolas"
                               FontSize="10"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Title"
                               Foreground="#70FFFFFF"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="0,0,0,4" />
                    <Border Background="#14FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,0,14">
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding TitleText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Text="Status Message"
                               Foreground="#70FFFFFF"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="0,0,0,4" />
                    <Border Background="#14FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,0,14">
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding StatusMessage, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Text="Dismiss Hint"
                               Foreground="#70FFFFFF"
                               FontFamily="Consolas"
                               FontSize="11"
                               Margin="0,0,0,4" />
                    <Border Background="#14FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,0,6">
                        <TextBox Style="{StaticResource SettingsInput}"
                                 Text="{Binding DismissText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Text="Supported: A-Z  0-9  Space  .  :  -"
                               Foreground="#35FFFFFF"
                               FontFamily="Consolas"
                               FontSize="10"
                               Margin="0,0,0,28" />

                    <TextBlock Text="BACKGROUND COLOR"
                               Foreground="#60FFFFFF"
                               FontFamily="Consolas"
                               FontSize="10"
                               Margin="0,0,0,12" />

                    <Border Background="#14FFFFFF"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,10">
                        <DockPanel LastChildFill="False">
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Left">
                                <Ellipse Width="14"
                                         Height="14"
                                         Fill="{Binding BackgroundBaseBrush}"
                                         Stroke="#55FFFFFF"
                                         StrokeThickness="1"
                                         Margin="0,0,8,0" />
                                <TextBlock Text="{Binding SelectedTheme}"
                                           Foreground="#E8FFFFFF"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource ThemeBtn}"
                                    Command="{Binding ToggleColorPaletteCommand}"
                                    Content="CHOOSE" />
                        </DockPanel>
                    </Border>

                    <Border Background="#0EFFFFFF"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10"
                            Margin="0,0,0,20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsColorPaletteOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <UniformGrid Columns="2">
                            <Button Margin="0,0,6,6"
                                    Command="{Binding ApplyThemeCommand}"
                                    CommandParameter="Blue">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ThemeBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTheme}" Value="Blue">
                                                <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#3658FF" Margin="0,0,7,0" />
                                    <TextBlock Text="BLUE" />
                                </StackPanel>
                            </Button>

                            <Button Margin="0,0,0,6"
                                    Command="{Binding ApplyThemeCommand}"
                                    CommandParameter="Purple">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ThemeBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTheme}" Value="Purple">
                                                <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#8200FF" Margin="0,0,7,0" />
                                    <TextBlock Text="PURPLE" />
                                </StackPanel>
                            </Button>

                            <Button Margin="0,0,6,6"
                                    Command="{Binding ApplyThemeCommand}"
                                    CommandParameter="Green">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ThemeBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTheme}" Value="Green">
                                                <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#00C850" Margin="0,0,7,0" />
                                    <TextBlock Text="GREEN" />
                                </StackPanel>
                            </Button>

                            <Button Margin="0,0,0,6"
                                    Command="{Binding ApplyThemeCommand}"
                                    CommandParameter="Ember">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ThemeBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTheme}" Value="Ember">
                                                <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#FF2800" Margin="0,0,7,0" />
                                    <TextBlock Text="EMBER" />
                                </StackPanel>
                            </Button>

                            <Button Margin="0,0,6,0"
                                    Command="{Binding ApplyThemeCommand}"
                                    CommandParameter="Mono">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ThemeBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTheme}" Value="Mono">
                                                <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="#AAAAAA" Margin="0,0,7,0" />
                                    <TextBlock Text="MONO" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
